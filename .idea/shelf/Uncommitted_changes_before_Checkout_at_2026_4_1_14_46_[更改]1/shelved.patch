+
+                tbody.innerHTML = '';
+                tbody.style.display = 'table-row-group';
+
+                if (tasks.length === 0) {
+                    emptyMsg.style.display = 'block';
+                    document.getElementById('taskTable').style.display = 'none';
+                    console.log('No tasks in database');
+                    return;
+                } else {
+                    emptyMsg.style.display = 'none';
+                    document.getElementById('taskTable').style.display = 'table';
+                }
+
+                tasks.forEach((task, index) => {
+                    console.log(`Rendering task ${index + 1}:`, task);
+                    const tr = document.createElement('tr');
+
+                    const taskId = task.id || '-';
+                    const title = task.title || 'N/A';
+                    const description = task.description || 'N/A';
+                    const priority = task.priority || 1;
+                    const dueDate = task.dueDate ? new Date(task.dueDate).toLocaleDateString() : 'N/A';
